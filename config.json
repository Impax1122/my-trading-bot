{
    "algorithm-type-name": "MyTradingBot",
    "algorithm-language": "Python",
    "algorithm-location": "main.py",
    "data-folder": "./data",
    "composer-dll-directory": ".",
    "log-handler": "CompositeLogHandler",
    "messaging-handler": "Messaging.Messaging",
    "job-queue-handler": "JobQueue.JobQueue",
    "api-handler": "Api.Api",
    "map-file-provider": "LocalDiskMapFileProvider",
    "factor-file-provider": "LocalDiskFactorFileProvider",
    "data-provider": "DefaultDataProvider",
    "alpha-handler": "DefaultAlphaHandler",
    "object-store": "LocalObjectStore",
    "results-destination-folder": "./results",
    "environments": {
        "backtesting": {
            "live-mode": false,
            "setup-handler": "Backtesting.BacktestingSetupHandler",
            "result-handler": "Backtesting.BacktestingResultHandler",
            "data-feed-handler": "FileSystemDataFeed",
            "real-time-handler": "Backtesting.BacktestingRealTimeHandler",
            "history-provider": "SubscriptionDataReaderHistoryProvider",
            "transaction-handler": "Backtesting.BacktestingTransactionHandler"
        },
        "live-paper": {
            "live-mode": true,
            "live-mode-brokerage": "PaperBrokerage",
            "setup-handler": "Brokerage.BrokerageSetupHandler",
            "result-handler": "LiveTrading.LiveTradingResultHandler",
            "data-feed-handler": "LiveTrading.DataFeed.LiveTradingDataFeed",
            "real-time-handler": "LiveTrading.LiveTradingRealTimeHandler",
            "transaction-handler": "Brokerage.BrokerageTransactionHandler"
        }
    },
    "environment": "backtesting"
}
